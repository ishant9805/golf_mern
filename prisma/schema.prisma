generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PUBLIC
  SUBSCRIBER
  ADMIN
}

enum SubscriptionPlan {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  INCOMPLETE
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum DrawType {
  RANDOM
  ALGORITHMIC
}

enum DrawStatus {
  DRAFT
  SIMULATED
  PUBLISHED
}

enum WinnerVerificationStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum PayoutStatus {
  PENDING
  PAID
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  passwordHash         String
  fullName             String
  role                 UserRole               @default(SUBSCRIBER)
  selectedCharityId    String?
  charityPercentage    Decimal                @db.Decimal(5, 2)
  stripeCustomerId     String?                @unique
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  selectedCharity      Charity?               @relation(fields: [selectedCharityId], references: [id])
  subscriptions        Subscription[]
  scores               Score[]
  winners              Winner[]
  payments             Payment[]
  charityContributions CharityContribution[]
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  plan                 SubscriptionPlan
  status               SubscriptionStatus
  stripeSubscriptionId String             @unique
  stripePriceId        String
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Score {
  id        String   @id @default(cuid())
  userId    String
  value     Int
  playedAt  DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, playedAt(sort: Desc)])
}

model Charity {
  id                   String                 @id @default(cuid())
  name                 String
  slug                 String                 @unique
  description          String
  mission              String
  imageUrl             String?
  location             String?
  featured             Boolean                @default(false)
  upcomingEvents       Json?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  users                User[]
  charityContributions CharityContribution[]
}

model Draw {
  id                String      @id @default(cuid())
  monthKey          String      @unique
  title             String
  drawType          DrawType
  status            DrawStatus  @default(DRAFT)
  generatedNumbers  Json
  simulationNumbers Json?
  prizePoolTotal    Decimal     @db.Decimal(12, 2)
  jackpotRollover   Decimal     @default(0) @db.Decimal(12, 2)
  notes             String?
  publishedAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  results           DrawResult[]
  winners           Winner[]
}

model DrawResult {
  id               String   @id @default(cuid())
  drawId           String
  tier             Int
  winnersCount     Int
  prizeAmount      Decimal  @db.Decimal(12, 2)
  amountPerWinner  Decimal  @db.Decimal(12, 2)
  rolloverApplied  Decimal  @default(0) @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  draw             Draw     @relation(fields: [drawId], references: [id], onDelete: Cascade)
}

model Winner {
  id                 String                    @id @default(cuid())
  userId             String
  drawId             String
  matchedCount       Int
  matchedNumbers     Json
  prizeAmount        Decimal                   @db.Decimal(12, 2)
  verificationStatus WinnerVerificationStatus  @default(PENDING)
  payoutStatus       PayoutStatus              @default(PENDING)
  proofImagePath     String?
  reviewedAt         DateTime?
  createdAt          DateTime                  @default(now())
  user               User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  draw               Draw                      @relation(fields: [drawId], references: [id], onDelete: Cascade)

  @@unique([userId, drawId, matchedCount])
}

model Payment {
  id                    String        @id @default(cuid())
  userId                String
  stripeInvoiceId       String?       @unique
  stripeCheckoutSession String?       @unique
  amount                Decimal       @db.Decimal(12, 2)
  currency              String
  status                PaymentStatus
  createdAt             DateTime      @default(now())
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CharityContribution {
  id          String   @id @default(cuid())
  userId      String
  charityId   String
  paymentId   String?  @unique
  amount      Decimal  @db.Decimal(12, 2)
  percentage  Decimal  @db.Decimal(5, 2)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  charity     Charity  @relation(fields: [charityId], references: [id], onDelete: Cascade)
}
